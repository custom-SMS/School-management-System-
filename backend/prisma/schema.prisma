datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SuperAdmin
  Admin        // legacy — kept for backward compat; real scoping via UserScope
  Cashier
  Teacher
  Student
  Parent
}

enum ScopeType {
  SchoolAdmin  // manages one entire school (all branches + levels)
  BranchAdmin  // manages one branch (all levels within it)
  LevelAdmin   // manages one level within one branch
  Cashier      // financial access scoped to a branch
}

enum AssignmentType {
  SubjectTeacher
  HomeRoomTeacher
}

// ─── School ───────────────────────────────────────────────────────────────────

model School {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  branches   Branch[]
  userScopes UserScope[]
}

// ─── Branch ───────────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  code      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  levels            EducationalLevel[]
  userScopes        UserScope[]
  classes           Class[]
  students          Student[]
  teachers          Teacher[]
  academicYears     AcademicYear[]
  feeStructures     FeeStructure[]
  gradingStructures GradingStructure[]
  subjects          Subject[]

  @@unique([schoolId, code])
}

// ─── EducationalLevel ─────────────────────────────────────────────────────────

model EducationalLevel {
  id         String   @id @default(uuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name       String   // e.g. "Kindergarten", "Elementary", "High School", "Preparatory"
  order      Int      @default(0)
  gradeRange String?  // e.g. "Grade 1–6"
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  userScopes        UserScope[]
  classes           Class[]
  students          Student[]
  gradingStructures GradingStructure[]

  @@unique([branchId, name])
}

// ─── UserScope ────────────────────────────────────────────────────────────────
// Links an Admin-type user to a School / Branch / Level scope

model UserScope {
  id        String            @id @default(uuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType ScopeType
  schoolId  String?
  school    School?           @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  branchId  String?
  branch    Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  levelId   String?
  level     EducationalLevel? @relation(fields: [levelId], references: [id], onDelete: SetNull)
  createdAt DateTime          @default(now())

  @@unique([userId, branchId, levelId])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  password  String
  role      Role
  roles     Role[]   @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  studentProfile          Student?
  teacherProfile          Teacher?
  parentProfile           Parent?
  userScope               UserScope[]
  recordedAttendance      Attendance[]
  assignedBy              TeacherAssignment[]       @relation("AssignedBy")
  gradedEntries           Grade[]
  verifiedPayments        Payment[]                 @relation("VerifiedPayments")
  issuedReceipts          Receipt[]                 @relation("IssuedReceipts")
  notifications           Notification[]
  auditLogs               AuditLog[]
  unlockRequestsRequested AttendanceUnlockRequest[] @relation("UnlockRequester")
  unlockRequestsApproved  AttendanceUnlockRequest[] @relation("UnlockApprover")
  promotedReportCards     ReportCard[]              @relation("PromotedBy")
}

// ─── RolePermission ───────────────────────────────────────────────────────────

model RolePermission {
  id         String   @id @default(uuid())
  role       Role
  permission String
  createdAt  DateTime @default(now())

  @@unique([role, permission])
}

// ─── AcademicYear ─────────────────────────────────────────────────────────────

model AcademicYear {
  id                String    @id @default(uuid())
  year              String
  branchId          String?   // null = global (legacy); set = branch-specific
  branch            Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  isActive          Boolean   @default(false)
  registrationOpen  Boolean   @default(false)
  registrationStart DateTime?
  registrationEnd   DateTime?
  createdAt         DateTime  @default(now())

  enrollments Enrollment[]
  attendances Attendance[]
  grades      Grade[]
  fees        Fee[]
  timetables  Timetable[]
  reportCards ReportCard[]
  semesters   Semester[]

  @@unique([year, branchId])
}

// ─── Semester ─────────────────────────────────────────────────────────────────
// Each AcademicYear has exactly two semesters. Only one semester is globally
// active at a time (isActive=true). SuperAdmin controls which is active.

model Semester {
  id             String       @id @default(uuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name           String       // "Semester 1" | "Semester 2"
  order          Int          // 1 or 2
  isActive       Boolean      @default(false)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime     @default(now())

  grades      Grade[]
  reportCards ReportCard[]
  timetables  Timetable[]

  @@unique([academicYearId, name])
  @@unique([academicYearId, order])
}

// ─── Student ──────────────────────────────────────────────────────────────────

model Student {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId        String   @unique
  grade            String
  stream           String?  // e.g. "Natural Science", "Social Science"
  branchId         String?
  branch           Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  levelId          String?
  level            EducationalLevel? @relation(fields: [levelId], references: [id], onDelete: SetNull)
  personalDetails  Json?
  familyBackground Json?
  guardianContacts Json?
  enrollmentDate   DateTime @default(now())

  guardians         Parent[]            @relation("StudentGuardians")
  classes           Class[]             @relation("ClassStudents")
  assignments       TeacherAssignment[] @relation("TeacherAssignmentStudents")
  grades            Grade[]
  fees              Fee[]
  attendanceRecords AttendanceRecord[]
  enrollments       Enrollment[]
  reportCards       ReportCard[]
}

// ─── Parent ───────────────────────────────────────────────────────────────────

model Parent {
  id           String   @id @default(uuid())
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId     String   @unique
  fullName     String
  email        String?
  phone        String?
  relationship String   @default("Parent")
  address      String?
  createdAt    DateTime @default(now())

  children Student[] @relation("StudentGuardians")
}

// ─── Enrollment ───────────────────────────────────────────────────────────────

model Enrollment {
  id             String       @id @default(uuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  grade          String
  stream         String?      // e.g. "Natural Science", "Social Science"
  sectionId      String?
  section        Section?     @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  status         String       @default("Enrolled")
  createdAt      DateTime     @default(now())

  @@unique([studentId, academicYearId])
}

// ─── Subject ──────────────────────────────────────────────────────────────────

model Subject {
  id            String   @id @default(uuid())
  name          String
  department    String?
  gradesOffered String[] @default([])
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  teacherAssignments TeacherAssignment[]
  grades             Grade[]
  timetables         Timetable[]
  classSubjects      ClassSubject[]

  @@unique([name, branchId])
}

// ─── Teacher ──────────────────────────────────────────────────────────────────

model Teacher {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId     String   @unique
  subject       String
  qualification String   @default("Degree")
  department    String   @default("General")
  status        String   @default("Active")
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  hireDate      DateTime @default(now())

  classes          Class[]
  assignments      TeacherAssignment[]
  homeroomSections Section[]
  classSubjects    ClassSubject[]
}

// ─── Section ──────────────────────────────────────────────────────────────────

model Section {
  id                String   @id @default(uuid())
  name              String
  classId           String
  class             Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  homeroomTeacherId String?
  homeroomTeacher   Teacher? @relation(fields: [homeroomTeacherId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())

  enrollments Enrollment[]
  timetables  Timetable[]
}

// ─── Class ────────────────────────────────────────────────────────────────────

model Class {
  id        String            @id @default(uuid())
  name      String
  teacherId String?
  teacher   Teacher?          @relation(fields: [teacherId], references: [id])
  subject   String?           // @deprecated: Use classSubjects relation instead
  schedule  String?
  branchId  String?
  branch    Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  levelId   String?
  level     EducationalLevel? @relation(fields: [levelId], references: [id], onDelete: SetNull)
  stream    String?
  createdAt DateTime          @default(now())

  students      Student[]           @relation("ClassStudents")
  attendances   Attendance[]
  grades       Grade[]
  assignments   TeacherAssignment[]
  sections      Section[]
  timetables    Timetable[]
  classSubjects ClassSubject[]
}

// ─── ClassSubject ─────────────────────────────────────────────────────────────
// Junction table to allow multiple subjects per class

model ClassSubject {
  id        String   @id @default(uuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId String?  // Optional: assign a specific teacher for this subject in this class
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@unique([classId, subjectId])
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model Attendance {
  id             String        @id @default(uuid())
  classId        String
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  date           DateTime      @default(now())
  recordedById   String
  recordedBy     User          @relation(fields: [recordedById], references: [id])
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  locked         Boolean       @default(false)
  createdAt      DateTime      @default(now())

  records        AttendanceRecord[]
  unlockRequests AttendanceUnlockRequest[]
}

model AttendanceRecord {
  id           String     @id @default(uuid())
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String
}

// ─── TeacherAssignment ────────────────────────────────────────────────────────

model TeacherAssignment {
  id             String         @id @default(uuid())
  teacherId      String
  teacher        Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classId        String?
  class          Class?         @relation(fields: [classId], references: [id])
  subjectId      String?
  subject        Subject?       @relation(fields: [subjectId], references: [id])
  assignmentType AssignmentType @default(SubjectTeacher)
  notes          String?
  assignedBy     User           @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedById   String
  createdAt      DateTime       @default(now())

  students Student[] @relation("TeacherAssignmentStudents")
}

// ─── GradingStructure ─────────────────────────────────────────────────────────

model GradingStructure {
  id               String   @id @default(uuid())
  branchId         String?
  branch           Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  levelId          String?
  level            EducationalLevel? @relation(fields: [levelId], references: [id], onDelete: SetNull)
  quizWeight       Float    @default(10)
  assignmentWeight Float    @default(20)
  midtermWeight    Float    @default(30)
  finalWeight      Float    @default(40)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
}

// ─── Timetable ────────────────────────────────────────────────────────────────

model Timetable {
  id             String       @id @default(uuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  semesterId     String?
  semester       Semester?    @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  classId        String
  class          Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  sectionId      String?
  section        Section?     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  dayOfWeek      String
  startTime      String
  endTime        String
  room           String?
  classroomId    String?
  classroom      Classroom?   @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id                   String    @id @default(uuid())
  feeId                String
  fee                  Fee       @relation(fields: [feeId], references: [id], onDelete: Cascade)
  amount               Float
  transactionReference String    @unique
  bankName             String
  receiptImageUrl      String?
  status               String    @default("Pending")
  verifiedById         String?
  verifiedBy           User?     @relation("VerifiedPayments", fields: [verifiedById], references: [id])
  paymentDate          DateTime  @default(now())
  verificationDate     DateTime?
  receipt              Receipt?
}

model Receipt {
  id            String   @id @default(uuid())
  receiptNumber String   @unique
  paymentId     String   @unique
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  issuedById    String
  issuedBy      User     @relation("IssuedReceipts", fields: [issuedById], references: [id])
  createdAt     DateTime @default(now())
}

// ─── Fee ──────────────────────────────────────────────────────────────────────

model Fee {
  id             String        @id @default(uuid())
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  amount         Float
  description    String
  month          String
  dueDate        DateTime
  paid           Boolean       @default(false)
  paymentDate    DateTime?
  createdAt      DateTime      @default(now())

  payments Payment[]
}

// ─── FeeStructure ─────────────────────────────────────────────────────────────

model FeeStructure {
  id          String   @id @default(uuid())
  grade       String
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  amount      Float
  description String?
  createdAt   DateTime @default(now())

  @@unique([grade, branchId])
}

// ─── Grade ────────────────────────────────────────────────────────────────────

model Grade {
  id             String            @id @default(uuid())
  studentId      String
  student        Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId        String
  class          Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject        String
  subjectId      String?
  subjectRef     Subject?          @relation(fields: [subjectId], references: [id])
  teacherId      String
  teacher        User              @relation(fields: [teacherId], references: [id])
  academicYearId String?
  academicYear   AcademicYear?     @relation(fields: [academicYearId], references: [id])
  semesterId     String?
  semester       Semester?         @relation(fields: [semesterId], references: [id])
  quiz           Float?
  assignment     Float?
  test           Float?
  midterm        Float?
  final          Float?
  maxTotal       Float             @default(100)
  total          Float             @default(0)
  percentage     Float             @default(0)
  comments       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action         String
  affectedRecord String?
  details        String?
  branchId       String?  // which branch this action occurred in
  timestamp      DateTime @default(now())
}

// ─── ReportCard ───────────────────────────────────────────────────────────────

model ReportCard {
  id                   String       @id @default(uuid())
  studentId            String
  student              Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId       String
  academicYear         AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  semesterId           String?
  semester             Semester?    @relation(fields: [semesterId], references: [id])
  // For Semester 2 report cards: snapshot of Semester 1 average for combined view
  semester1Snapshot    Float?
  grade                String
  attendancePercentage Float
  attendancePresent    Int          @default(0)
  attendanceAbsent     Int          @default(0)
  attendanceLate       Int          @default(0)
  attendanceTotal      Int          @default(0)
  averageScore         Float
  combinedAverage      Float?       // Semester 2 only: (sem1 + sem2) / 2
  rank                 Int?
  status               String       @default("Pending")
  teacherComments      String?
  homeroomRemarks      String?
  conductGrade         String?
  workflowStatus       String       @default("Draft")
  published            Boolean      @default(false)
  promotionStatus      String       @default("Pending")
  promotedById         String?
  promotedBy           User?        @relation("PromotedBy", fields: [promotedById], references: [id])
  promotionDate        DateTime?
  createdAt            DateTime     @default(now())

  // Two report cards per year: one per semester
  @@unique([studentId, academicYearId, semesterId])
}

// ─── Misc ─────────────────────────────────────────────────────────────────────

model GradeFee {  id     String @id @default(uuid())
  grade  String @unique
  amount Float
}

model Counter {
  id  String @id
  seq Int    @default(0)
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Classroom {
  id         String      @id @default(uuid())
  name       String
  number     String      @unique
  capacity   Int
  building   String
  status     String      @default("Active")
  createdAt  DateTime    @default(now())
  timetables Timetable[]
}

model AttendanceUnlockRequest {
  id              String     @id @default(uuid())
  attendanceId    String
  attendance      Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  teacherId       String
  teacher         User       @relation("UnlockRequester", fields: [teacherId], references: [id], onDelete: Cascade)
  reason          String
  status          String     @default("Pending")
  approverId      String?
  approver        User?      @relation("UnlockApprover", fields: [approverId], references: [id], onDelete: SetNull)
  rejectionReason String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

