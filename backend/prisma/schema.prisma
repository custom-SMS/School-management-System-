datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SuperAdmin
  Admin
  Cashier
  Teacher
  Student
  Parent
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  password  String
  role      Role
  roles     Role[]   @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  // Relations
  studentProfile          Student?
  teacherProfile          Teacher?
  parentProfile           Parent?
  recordedAttendance      Attendance[]
  assignedBy              TeacherAssignment[]       @relation("AssignedBy")
  gradedEntries           Grade[]
  verifiedPayments        Payment[]                 @relation("VerifiedPayments")
  issuedReceipts          Receipt[]                 @relation("IssuedReceipts")
  notifications           Notification[]
  auditLogs               AuditLog[]
  unlockRequestsRequested AttendanceUnlockRequest[] @relation("UnlockRequester")
  unlockRequestsApproved  AttendanceUnlockRequest[] @relation("UnlockApprover")
  promotedReportCards     ReportCard[]              @relation("PromotedBy")
}

model RolePermission {
  id         String   @id @default(uuid())
  role       Role
  permission String
  createdAt  DateTime @default(now())

  @@unique([role, permission])
}

model AcademicYear {
  id                String    @id @default(uuid())
  year              String    @unique
  isActive          Boolean   @default(false)
  registrationOpen  Boolean   @default(false)
  registrationStart DateTime?
  registrationEnd   DateTime?
  createdAt         DateTime  @default(now())

  // Relations
  enrollments Enrollment[]
  attendances Attendance[]
  grades      Grade[]
  fees        Fee[]
  timetables  Timetable[]
  reportCards ReportCard[]
}

model Student {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId        String   @unique
  grade            String
  personalDetails  Json?
  familyBackground Json?
  guardianContacts Json?
  enrollmentDate   DateTime @default(now())

  // Relations
  guardians         Parent[]            @relation("StudentGuardians")
  classes           Class[]             @relation("ClassStudents")
  assignments       TeacherAssignment[] @relation("TeacherAssignmentStudents")
  grades            Grade[]
  fees              Fee[]
  attendanceRecords AttendanceRecord[]
  enrollments       Enrollment[]
  reportCards       ReportCard[]
}

model Parent {
  id           String   @id @default(uuid())
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId     String   @unique
  fullName     String
  email        String?
  phone        String?
  relationship String   @default("Parent")
  address      String?
  createdAt    DateTime @default(now())

  // Relations
  children Student[] @relation("StudentGuardians")
}

model Enrollment {
  id             String       @id @default(uuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  grade          String
  sectionId      String?
  section        Section?     @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  status         String       @default("Enrolled")
  createdAt      DateTime     @default(now())

  @@unique([studentId, academicYearId])
}

model Subject {
  id            String   @id @default(uuid())
  name          String   @unique
  department    String?
  gradesOffered String[] @default([])
  createdAt     DateTime @default(now())

  // Relations
  teacherAssignments TeacherAssignment[]
  grades             Grade[]
  timetables         Timetable[]
}

model Teacher {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId     String   @unique
  subject       String
  qualification String   @default("Degree")
  department    String   @default("General")
  status        String   @default("Active")
  hireDate      DateTime @default(now())

  // Relations
  classes          Class[]
  assignments      TeacherAssignment[]
  homeroomSections Section[]
}

model Section {
  id                String   @id @default(uuid())
  name              String
  classId           String
  class             Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  homeroomTeacherId String?
  homeroomTeacher   Teacher? @relation(fields: [homeroomTeacherId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())

  // Relations
  enrollments Enrollment[]
  timetables  Timetable[]
}

model Class {
  id        String   @id @default(uuid())
  name      String
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  subject   String
  schedule  String?
  createdAt DateTime @default(now())

  // Relations
  students    Student[]           @relation("ClassStudents")
  attendances Attendance[]
  grades      Grade[]
  assignments TeacherAssignment[]
  sections    Section[]
  timetables  Timetable[]
}

model Attendance {
  id             String        @id @default(uuid())
  classId        String
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  date           DateTime      @default(now())
  recordedById   String
  recordedBy     User          @relation(fields: [recordedById], references: [id])
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  locked         Boolean       @default(false)
  createdAt      DateTime      @default(now())

  // Relations
  records        AttendanceRecord[]
  unlockRequests AttendanceUnlockRequest[]
}

model AttendanceRecord {
  id           String     @id @default(uuid())
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String
}

enum AssignmentType {
  SubjectTeacher
  HomeRoomTeacher
}

model TeacherAssignment {
  id             String         @id @default(uuid())
  teacherId      String
  teacher        Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classId        String?
  class          Class?         @relation(fields: [classId], references: [id])
  subjectId      String?
  subject        Subject?       @relation(fields: [subjectId], references: [id])
  assignmentType AssignmentType @default(SubjectTeacher)
  notes          String?
  assignedBy     User           @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedById   String
  createdAt      DateTime       @default(now())

  // Relations
  students Student[] @relation("TeacherAssignmentStudents")
}

model GradingStructure {
  id               String   @id @default(uuid())
  quizWeight       Float    @default(10)
  assignmentWeight Float    @default(20)
  midtermWeight    Float    @default(30)
  finalWeight      Float    @default(40)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
}

model Timetable {
  id             String       @id @default(uuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classId        String
  class          Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  sectionId      String?
  section        Section?     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  dayOfWeek      String
  startTime      String
  endTime        String
  room           String?
  classroomId    String?
  classroom      Classroom?   @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
}

model Payment {
  id                   String    @id @default(uuid())
  feeId                String
  fee                  Fee       @relation(fields: [feeId], references: [id], onDelete: Cascade)
  amount               Float
  transactionReference String    @unique
  bankName             String
  status               String    @default("Pending")
  verifiedById         String?
  verifiedBy           User?     @relation("VerifiedPayments", fields: [verifiedById], references: [id])
  paymentDate          DateTime  @default(now())
  verificationDate     DateTime?
  receipt              Receipt?
}

model Receipt {
  id            String   @id @default(uuid())
  receiptNumber String   @unique
  paymentId     String   @unique
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  issuedById    String
  issuedBy      User     @relation("IssuedReceipts", fields: [issuedById], references: [id])
  createdAt     DateTime @default(now())
}

model Fee {
  id             String        @id @default(uuid())
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  amount         Float
  description    String
  month          String
  dueDate        DateTime
  paid           Boolean       @default(false)
  paymentDate    DateTime?
  createdAt      DateTime      @default(now())

  // Relations
  payments Payment[]
}

model FeeStructure {
  id          String   @id @default(uuid())
  grade       String   @unique
  amount      Float
  description String?
  createdAt   DateTime @default(now())
}

model Grade {
  id             String        @id @default(uuid())
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId        String
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject        String
  subjectId      String?
  subjectRef     Subject?      @relation(fields: [subjectId], references: [id])
  teacherId      String
  teacher        User          @relation(fields: [teacherId], references: [id])
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  quiz           Float?
  assignment     Float?
  test           Float?
  midterm        Float?
  final          Float?
  maxTotal       Float         @default(100)
  total          Float         @default(0)
  percentage     Float         @default(0)
  comments       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action         String
  affectedRecord String?
  details        String?
  timestamp      DateTime @default(now())
}

model ReportCard {
  id                   String       @id @default(uuid())
  studentId            String
  student              Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId       String
  academicYear         AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  grade                String
  attendancePercentage Float
  attendancePresent    Int          @default(0)
  attendanceAbsent     Int          @default(0)
  attendanceLate       Int          @default(0)
  attendanceTotal      Int          @default(0)
  averageScore         Float
  rank                 Int?
  status               String       @default("Pending") // Pass / Fail / Pending
  teacherComments      String?      // Subject teacher comments
  homeroomRemarks      String?      // Homeroom teacher remarks
  conductGrade         String?      // e.g. "Excellent", "Good", "Satisfactory", "Needs Improvement"
  workflowStatus       String       @default("Draft")
  // Draft → HomeroomReview → AdminReview → Published
  published            Boolean      @default(false)
  promotionStatus      String       @default("Pending")
  promotedById         String?
  promotedBy           User?        @relation("PromotedBy", fields: [promotedById], references: [id])
  promotionDate        DateTime?
  createdAt            DateTime     @default(now())

  @@unique([studentId, academicYearId])
}

model GradeFee {
  id     String @id @default(uuid())
  grade  String @unique
  amount Float
}

model Counter {
  id  String @id
  seq Int    @default(0)
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Classroom {
  id         String      @id @default(uuid())
  name       String
  number     String      @unique
  capacity   Int
  building   String
  status     String      @default("Active")
  createdAt  DateTime    @default(now())
  timetables Timetable[]
}

model AttendanceUnlockRequest {
  id              String     @id @default(uuid())
  attendanceId    String
  attendance      Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  teacherId       String
  teacher         User       @relation("UnlockRequester", fields: [teacherId], references: [id], onDelete: Cascade)
  reason          String
  status          String     @default("Pending")
  approverId      String?
  approver        User?      @relation("UnlockApprover", fields: [approverId], references: [id], onDelete: SetNull)
  rejectionReason String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}
