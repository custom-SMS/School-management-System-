datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  Admin
  Teacher
  Student
  Parent
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  // Relations
  studentProfile     Student?
  teacherProfile     Teacher?
  parentProfile      Parent?
  recordedAttendance Attendance[]
  assignedBy         TeacherAssignment[] @relation("AssignedBy")
  gradedEntries      Grade[]
}

model Student {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId        String   @unique
  grade            String
  personalDetails  Json? // { dateOfBirth, gender, phone, address, admissionDate }
  familyBackground Json? // { fatherName, motherName, guardianName, occupation, notes }
  guardianContacts Json? // Array of embedded guardian contact details
  enrollmentDate   DateTime @default(now())

  // Relations
  guardians         Parent[]            @relation("StudentGuardians")
  classes           Class[]             @relation("ClassStudents")
  assignments       TeacherAssignment[] @relation("TeacherAssignmentStudents")
  grades            Grade[]
  fees              Fee[]
  attendanceRecords AttendanceRecord[]
}

model Parent {
  id           String   @id @default(uuid())
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId     String   @unique
  fullName     String
  email        String?
  phone        String?
  relationship String   @default("Parent")
  address      String?
  createdAt    DateTime @default(now())

  // Relations
  children Student[] @relation("StudentGuardians")
}

model Teacher {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId String   @unique
  subject   String
  hireDate  DateTime @default(now())

  // Relations
  classes     Class[]
  assignments TeacherAssignment[]
}

model Class {
  id        String   @id @default(uuid())
  name      String
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  subject   String
  schedule  String?
  createdAt DateTime @default(now())

  // Relations
  students    Student[]           @relation("ClassStudents")
  attendances Attendance[]
  grades      Grade[]
  assignments TeacherAssignment[]
}

model Attendance {
  id           String   @id @default(uuid())
  classId      String
  class        Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  date         DateTime @default(now())
  recordedById String
  recordedBy   User     @relation(fields: [recordedById], references: [id])
  createdAt    DateTime @default(now())

  // Relations
  records AttendanceRecord[]
}

model AttendanceRecord {
  id           String     @id @default(uuid())
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String // "Present", "Absent", "Late"
}

model TeacherAssignment {
  id           String   @id @default(uuid())
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classId      String?
  class        Class?   @relation(fields: [classId], references: [id])
  notes        String?
  assignedBy   User     @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedById String
  createdAt    DateTime @default(now())

  // Relations
  students Student[] @relation("TeacherAssignmentStudents")
}

model Fee {
  id          String    @id @default(uuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount      Float
  description String
  month       String
  dueDate     DateTime
  paid        Boolean   @default(false)
  paymentDate DateTime?
  createdAt   DateTime  @default(now())
}

model Grade {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   String
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id])
  test      Float    @default(0)
  midterm   Float    @default(0)
  final     Float    @default(0)
  maxTotal  Float    @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GradeFee {
  id     String @id @default(uuid())
  grade  String @unique
  amount Float
}

model Counter {
  id  String @id
  seq Int    @default(0)
}
